# DexScreener currently requires no API key for public endpoints.

# GeckoTerminal public API base. Use this to override the default in live adapters.
GECKOTERMINAL_API_BASE=https://api.geckoterminal.com/api/v2

# CoinGecko demo/pro key for global metrics and categories.
# Obtain from https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Helius key for Solana token metadata, holders, and transfers.
# Obtain from https://www.helius.dev/
HELIUS_API_KEY=

# GoPlus Security API key if required by the selected endpoint/tier.
# Obtain from https://gopluslabs.io/
GOPLUS_API_KEY=

# RugCheck API key if required by the selected endpoint/tier.
# Obtain from https://rugcheck.xyz/
RUGCHECK_API_KEY=

# Anthropic key for the future live AI research agent.
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Upstash Redis REST credentials for live-source caching and rate-limit state.
# Obtain from https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase project credentials for persisted users, watchlists, alert rules, and score snapshots.
# Obtain from https://supabase.com/
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram bot delivery settings for future alert delivery.
# Create a bot with BotFather and provide a chat id from Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
