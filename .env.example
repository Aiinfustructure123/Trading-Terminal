# DexScreener is a free public API; no key is required for Phase 1 market panels.

# GeckoTerminal public API / optional demo credentials for OHLCV and pool backup data.
GECKOTERMINAL_API_KEY=

# CoinGecko demo/pro API key for global metrics, categories, and market caps.
COINGECKO_API_KEY=

# Helius API key for Solana token metadata, holders, transfers, and portfolio expansion.
HELIUS_API_KEY=

# GoPlus Security API key when required for chain-specific security reports.
GOPLUS_API_KEY=

# RugCheck API key or token if future access requires authenticated Solana risk reports.
RUGCHECK_API_KEY=

# Anthropic API key for live AI research briefs and scenario generation.
ANTHROPIC_API_KEY=

# Supabase project credentials for users, watchlists, alert rules, and score snapshots.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis REST credentials for external API caching and rate-limit coordination.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional Telegram bot credentials for Phase 3 alert delivery.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
