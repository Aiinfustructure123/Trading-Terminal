# ALPHA TERMINAL — environment variables
# Phase 0 runs entirely on sample data and needs NO keys.
# These slots anticipate Phase 1+; each comment says where to obtain the key.

# DexScreener — primary market data (pairs, price, volume, liquidity, txns).
# Free, no key required today; slot reserved for future authenticated tiers.
# https://docs.dexscreener.com/api/reference
DEXSCREENER_API_KEY=

# GeckoTerminal — OHLCV candles, pool data, trending pools.
# https://www.geckoterminal.com/dex-api
GECKOTERMINAL_API_KEY=

# CoinGecko — market caps, categories, global metrics (free demo key).
# https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# Helius — Solana holders, transfers, token metadata (free tier).
# https://dashboard.helius.dev
HELIUS_API_KEY=

# GoPlus Security — honeypot, mint/freeze authority, taxes, LP lock (free).
# https://gopluslabs.io/security-api
GOPLUS_API_KEY=

# RugCheck — Solana token risk reports.
# https://api.rugcheck.xyz
RUGCHECK_API_KEY=

# Anthropic — Claude generates research briefs & scenarios (Phase 2).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Upstash Redis — caching layer for live sources (Phase 1).
# https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase (Postgres) — tokens, score_snapshots, watchlist_items, alert_rules, users (Phase 1).
# https://supabase.com/dashboard → project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram bot — alert delivery (Phase 3). Create via @BotFather.
# https://core.telegram.org/bots#how-do-i-create-a-bot
TELEGRAM_BOT_TOKEN=
