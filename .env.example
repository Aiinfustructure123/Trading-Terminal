# ──────────────────────────────────────────────────────────────────────────────
# ALPHA TERMINAL — environment variables
#
# Phase 0 runs entirely on sample data and requires NONE of these. Each key is
# needed only when its corresponding source is flipped to "live" in
# src/lib/datasources/config.ts. Copy this file to `.env.local` and fill in keys
# as you bring each source online.
# ──────────────────────────────────────────────────────────────────────────────

# ── Market data (Phase 1) ────────────────────────────────────────────────────
# DexScreener — pairs, price, volume, liquidity, new launches (free, 300 req/min)
# Where: https://docs.dexscreener.com/api/reference  (no key required for most endpoints)
DEXSCREENER_API_KEY=
# GeckoTerminal — OHLCV candles, pool data, trending pools (free)
# Where: https://www.geckoterminal.com/dex-api
GECKOTERMINAL_API_KEY=
# CoinGecko — market caps, categories, global metrics (free/demo key, cache 15 min)
# Where: https://www.coingecko.com/en/api/pricing  → create a Demo API key
COINGECKO_API_KEY=

# ── On-chain & forensics (Phase 1) ───────────────────────────────────────────
# Helius — Solana holders, transfers, token metadata (free tier)
# Where: https://dev.helius.xyz  → Dashboard → API Keys
HELIUS_API_KEY=
# GoPlus Security — honeypot, mint/freeze authority, taxes, LP lock (free)
# Where: https://gopluslabs.io/security-api
GOPLUS_API_KEY=
# RugCheck — Solana token risk reports
# Where: https://rugcheck.xyz
RUGCHECK_API_KEY=

# ── AI research (Phase 2) ─────────────────────────────────────────────────────
# Anthropic Claude — research briefs & scenario generation (claude-sonnet-4-6)
# Where: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Alerts delivery (Phase 3) ─────────────────────────────────────────────────
# Telegram bot — alert delivery. Create a bot via @BotFather, then capture chat id.
# Where: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Infrastructure (Phase 1) ──────────────────────────────────────────────────
# Supabase (Postgres): tokens, score_snapshots, watchlist_items, alert_rules, users
# Where: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Upstash Redis — response caching & rate-limit awareness for live sources (free tier)
# Where: https://upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
