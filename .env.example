# AlphaTerminal — Environment Variables
# Copy this file to .env.local and populate the keys.
# All keys are optional in Phase 0 (sample data mode).

# ── Phase 1 — Market Data ─────────────────────────────────────────────────────

# DexScreener: free, no key required; add key for higher rate limits
# https://docs.dexscreener.com
NEXT_PUBLIC_DEXSCREENER_API_KEY=

# GeckoTerminal: free tier, no key required
# https://www.geckoterminal.com/dex-api
NEXT_PUBLIC_GECKOTERMINAL_API_KEY=

# CoinGecko: free demo key from https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Helius: free tier from https://helius.dev — Solana on-chain data
HELIUS_API_KEY=

# GoPlus Security: free tier from https://docs.gopluslabs.io — honeypot, mint/freeze
GOPLUS_API_KEY=

# RugCheck: Solana token risk reports — https://rugcheck.xyz
RUGCHECK_API_KEY=

# ── Phase 1 — Infrastructure ──────────────────────────────────────────────────

# Supabase: database for tokens, scores, watchlist, alerts
# https://supabase.com/docs/guides/getting-started
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis: API response caching — https://upstash.com/docs
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Phase 2 — AI ──────────────────────────────────────────────────────────────

# Anthropic: AI research briefs via Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Phase 3 — Alerts ──────────────────────────────────────────────────────────

# Telegram bot: user-supplied token + chat ID for alert delivery
# https://core.telegram.org/bots/tutorial
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
